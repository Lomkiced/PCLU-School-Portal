{
    "expo": {
        "name": "PCLU School Portal",
        "slug": "pclu-school-portal",
        "version": "1.0.0",
        "orientation": "portrait",
        "icon": "./assets/icon.png",
        "scheme": "pclu",
        "userInterfaceStyle": "automatic",
        "newArchEnabled": true,
        "splash": {
            "image": "./assets/splash-icon.png",
            "resizeMode": "contain",
            "backgroundColor": "#1a1f6e"
        },
        "ios": {
            "supportsTablet": true,
            "bundleIdentifier": "ph.edu.pclu.portal",
            "infoPlist": {
                "NSCameraUsageDescription": "Camera is used for QR code scanning for attendance"
            }
        },
        "android": {
            "adaptiveIcon": {
                "foregroundImage": "./assets/adaptive-icon.png",
                "backgroundColor": "#1a1f6e"
            },
            "package": "ph.edu.pclu.portal",
            "permissions": [
                "CAMERA"
            ]
        },
        "plugins": [
            "expo-router",
            "expo-secure-store",
            [
                "expo-camera",
                {
                    "cameraPermission": "Allow PCLU Portal to access your camera for QR attendance scanning."
                }
            ],
            [
                "expo-notifications",
                {
                    "icon": "./assets/notification-icon.png",
                    "color": "#1a1f6e"
                }
            ]
        ]
    }
}