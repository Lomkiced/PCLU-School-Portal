{
    "$schema": "https://json.schemastore.org/tsconfig",
    "display": "React Native",
    "extends": "./base.json",
    "compilerOptions": {
        "allowJs": true,
        "jsx": "react-native",
        "lib": [
            "DOM",
            "ESNext"
        ],
        "moduleResolution": "node",
        "skipLibCheck": true,
        "target": "esnext"
    },
    "exclude": [
        "node_modules"
    ]
}